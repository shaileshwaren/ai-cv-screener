# ─────────────────────────────────────────────────
# Manatal + OpenAI
# ─────────────────────────────────────────────────
MANATAL_API_TOKEN=your_manatal_token_here
OPENAI_API_KEY=your_openai_key_here

# ─────────────────────────────────────────────────
# Airtable
# ─────────────────────────────────────────────────
AIRTABLE_TOKEN=your_airtable_pat_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_CANDIDATE_TABLE_ID=tblXXXXXXXXXXXXXX   # Candidate table
AIRTABLE_JOB_TABLE_ID=tblXXXXXXXXXXXXXX     # Job table
# Optional: single-row settings table; filter {Recordnum}=1. Fields: tier1_pass_threshold, tier2_pass_threshold, tier2_must_have_floor
# AIRTABLE_PIPELINE_SETTINGS_TABLE_ID=tblXXXXXXXXXXXXXX

# ─────────────────────────────────────────────────
# Pipeline settings (optional overrides)
# ─────────────────────────────────────────────────
TIER1_PASS_THRESHOLD=60
# Legacy alias still supported: PASS_THRESHOLD=60
# Tier 2 pass threshold (overall_score). If unset or non-numeric, matches TIER1_PASS_THRESHOLD.
# TIER2_PASS_THRESHOLD=60
# Must-have score floor (scale 0–5): any must-have below this triggers FAIL. Default 2.0.
# MUST_HAVE_FLOOR_RULE=2.0
# Legacy alias still supported: TIER2_MUST_HAVE_FLOOR=2.0
TARGET_STAGE_NAME=New Candidates
TARGET_STAGE_AFTER=AI Screened
TARGET_STAGE_FAIL=Processed
# Omit dropped job-matches (Manatal match.dropped_at). Default true; set false only for debugging.
# EXCLUDE_DROPPED_MATCHES=true
